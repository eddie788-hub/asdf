// ============================================
// ML BEHAVIORAL MODEL
// ============================================

class BehavioralMLModel {
  constructor() {
    this.requestHistory = [];
    this.blockedPatterns = [];
    this.successPatterns = [];
    this.currentBehavior = 'normal';
    this.currentDelay = EVASION_CONFIG.REQUEST_INTERVAL.NORMAL;
    this.learningRate = 0.1;
  }

  learnSuccess(request) {
    this.successPatterns.push({
      timestamp: Date.now(),
      headers: request.headers,
      interval: request.interval,
      url: request.url
    });
    if (this.successPatterns.length > 1000) this.successPatterns.shift();
    this.adaptBehavior();
  }

  learnBlock(block) {
    this.blockedPatterns.push({
      timestamp: Date.now(),
      reason: block.reason,
      url: block.url,
      statusCode: block.statusCode
    });
    if (this.blockedPatterns.length > 100) this.blockedPatterns.shift();
    
    if (this.blockedPatterns.filter(b => Date.now() - b.timestamp < 300000).length > 3) {
      this.currentBehavior = 'stealth';
      this.currentDelay = EVASION_CONFIG.REQUEST_INTERVAL.STEALTH;
    }
    this.adaptBehavior();
  }

  adaptBehavior() {
    const avgSuccessInterval = this.successPatterns.reduce((sum, p) => sum + p.interval, 0) / (this.successPatterns.length || 1);
    const recentBlocks = this.blockedPatterns.filter(b => Date.now() - b.timestamp < 300000).length;
    
    if (recentBlocks > 3) {
      this.currentBehavior = 'stealth';
      this.currentDelay = EVASION_CONFIG.REQUEST_INTERVAL.STEALTH;
    } else if (avgSuccessInterval < 2000 && this.successPatterns.length > 20) {
      this.currentBehavior = 'aggressive';
      this.currentDelay = EVASION_CONFIG.REQUEST_INTERVAL.AGGRESSIVE;
    } else {
      this.currentBehavior = 'normal';
      this.currentDelay = EVASION_CONFIG.REQUEST_INTERVAL.NORMAL;
    }
  }

  getNextDelay() {
    let delay = this.currentDelay;
    if (EVASION_CONFIG.HUMAN_BEHAVIOR.RANDOM_PAUSES && Math.random() < 0.1) {
      delay += Math.random() * 5000;
    }
    delay *= (1 + (Math.random() - 0.5) * EVASION_CONFIG.ROTATION.REQUEST_DELAY_JITTER);
    return Math.max(500, Math.min(30000, delay));
  }

  predictSafety(url) {
    const blockedDomain = this.blockedPatterns.some(b => url.includes(b.url?.split('/')[2] || ''));
    if (blockedDomain) return 0.2;
    return 0.7;
  }

  getStatus() {
    return {
      behavior: this.currentBehavior,
      delay: Math.round(this.currentDelay),
      learnedPatterns: this.successPatterns.length,
      blocksAvoided: this.blockedPatterns.length
    };
  }
}

// ============================================
// THROTTLING MANAGER
// ============================================

class ThrottlingManager {
  constructor() {
    this.requestCount = 0;
    this.requestWindow = [];
    this.cooldownActive = false;
    this.cooldownEndTime = null;
    this.lastCooldownTime = null;
    this.domainRequestCount = new Map();
    this.crawlStartTime = null;
  }

  startCrawl() {
    this.crawlStartTime = Date.now();
    localStorage.setItem('crawlStartTime', this.crawlStartTime.toString());
  }

  needsCooldown() {
    const now = Date.now();
    if (this.cooldownActive && this.cooldownEndTime > now) return true;
    if (this.lastCooldownTime && (now - this.lastCooldownTime) < EVASION_CONFIG.COOLDOWN.INTERVAL) return false;
    if (this.crawlStartTime && (now - this.crawlStartTime) >= EVASION_CONFIG.COOLDOWN.INTERVAL) {
      this.startCooldown();
      return true;
    }
    return false;
  }

  startCooldown() {
    this.cooldownActive = true;
    this.cooldownEndTime = Date.now() + EVASION_CONFIG.COOLDOWN.DURATION;
    this.lastCooldownTime = Date.now();
    localStorage.setItem('cooldownEndTime', this.cooldownEndTime.toString());
    localStorage.setItem('lastCooldownTime', this.lastCooldownTime.toString());
  }

  endCooldown() {
    this.cooldownActive = false;
    this.cooldownEndTime = null;
    this.requestCount = 0;
    this.requestWindow = [];
    localStorage.removeItem('cooldownEndTime');
    this.startCrawl();
  }

  getCooldownRemaining() {
    if (!this.cooldownActive || !this.cooldownEndTime) return 0;
    return Math.max(0, this.cooldownEndTime - Date.now());
  }

  trackRequest(domain) {
    const count = this.domainRequestCount.get(domain) || 0;
    this.domainRequestCount.set(domain, count + 1);
    this.requestCount++;
    this.requestWindow.push(Date.now());
    if (this.requestWindow.length > 100) this.requestWindow.shift();
  }

  getCurrentRate() {
    const now = Date.now();
    const lastMinute = this.requestWindow.filter(ts => now - ts < 60000);
    return lastMinute.length;
  }

  getAdaptiveDelay() {
    const rate = this.getCurrentRate();
    if (rate > 30) return 5000;
    if (rate > 20) return 3000;
    if (rate > 10) return 2000;
    return 1000;
  }

  getStatus() {
    return {
      cooldownActive: this.cooldownActive,
      cooldownRemaining: this.getCooldownRemaining(),
      requestRate: this.getCurrentRate(),
      totalRequests: this.requestCount,
      domainsTracked: this.domainRequestCount.size
    };
  }
}

// ============================================
// ML POWERED CRAWLER
// ============================================

class MLPoweredCrawler {
  constructor() {
    this.mlModel = new BehavioralMLModel();
    this.throttler = new ThrottlingManager();
    this.sessionCookies = new Map();
    this.currentUserAgent = EVASION_CONFIG.ROTATION.USER_AGENTS[0];
    this.requestCount = 0;
    this.isRunning = false;
    this.onFinding = null;
  }

  setCallbacks(onFinding, onStatusUpdate) {
    this.onFinding = onFinding;
    this.onStatusUpdate = onStatusUpdate;
  }

  rotateUserAgent() {
    if (this.requestCount % EVASION_CONFIG.ROTATION.ROTATE_EVERY === 0) {
      const randomIndex = Math.floor(Math.random() * EVASION_CONFIG.ROTATION.USER_AGENTS.length);
      this.currentUserAgent = EVASION_CONFIG.ROTATION.USER_AGENTS[randomIndex];
    }
  }

  generateHeaders(url) {
    this.rotateUserAgent();
    const headers = {
      'User-Agent': this.currentUserAgent,
      'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
      'Accept-Language': 'en-US,en;q=0.5',
      'Accept-Encoding': 'gzip, deflate, br',
      'Connection': 'keep-alive',
      'Upgrade-Insecure-Requests': '1'
    };
    
    if (EVASION_CONFIG.EVASION.FAKE_REFERRERS) {
      const referrers = ['https://www.google.com/', 'https://www.bing.com/', 'https://duckduckgo.com/'];
      headers['Referer'] = referrers[Math.floor(Math.random() * referrers.length)];
    }
    
    const domain = new URL(url).hostname;
    if (this.sessionCookies.has(domain)) {
      headers['Cookie'] = this.sessionCookies.get(domain);
    }
    
    return headers;
  }

  async intelligentCrawl(url, depth) {
    if (this.throttler.needsCooldown()) {
      throw new Error('Cooldown active');
    }
    
    const safetyScore = this.mlModel.predictSafety(url);
    if (safetyScore < 0.3) return null;
    
    const domain = new URL(url).hostname;
    this.throttler.trackRequest(domain);
    
    const adaptiveDelay = this.throttler.getAdaptiveDelay();
    const mlDelay = this.mlModel.getNextDelay();
    const delay = Math.max(adaptiveDelay, mlDelay);
    
    await this.humanLikeDelay(delay);
    const headers = this.generateHeaders(url);
    
    try {
      const response = await this.makeRequest(url, headers);
      this.mlModel.learnSuccess({ url, headers, interval: delay, timestamp: Date.now() });
      this.requestCount++;
      return response;
    } catch (error) {
      this.mlModel.learnBlock({ url, reason: error.message, statusCode: error.statusCode || 500, timestamp: Date.now() });
      throw error;
    }
  }

  async makeRequest(url, headers) {
    await new Promise(resolve => setTimeout(resolve, 300 + Math.random() * 400));
    const rand = Math.random();
    if (rand < 0.02) throw { message: 'Rate limited', statusCode: 429 };
    if (rand < 0.01) throw { message: 'Access denied', statusCode: 403 };
    
    return {
      status: 200,
      headers,
      content: this.generateMockContent(url),
      cookies: `session=${Math.random().toString(36).substring(7)}`
    };
  }

  generateMockContent(url) {
    const iocs = [
      { type: 'ip_address', value: `185.${Math.floor(Math.random() * 255)}.${Math.floor(Math.random() * 255)}.${Math.floor(Math.random() * 255)}` },
      { type: 'domain', value: `malicious-${Math.random().toString(36).substring(7)}.com` },
      { type: 'hash', value: Math.random().toString(36).substring(2, 15) },
      { type: 'cve', value: `CVE-2024-${Math.floor(Math.random() * 10000)}` },
      { type: 'url', value: `http://evil-${Math.random().toString(36).substring(7)}.ru/payload` }
    ];
    return JSON.stringify({ url, iocs: iocs.slice(0, 3), timestamp: Date.now() });
  }

  async humanLikeDelay(baseDelay) {
    let delay = baseDelay * (1 + (Math.random() - 0.5) * 0.4);
    if (Math.random() < 0.1) {
      delay += Math.random() * 5000;
      this.onStatusUpdate?.('📖 Simulating human reading pause...');
    }
    await new Promise(resolve => setTimeout(resolve, delay));
    return delay;
  }

  async startCrawling(seedUrls) {
    this.isRunning = true;
    this.throttler.startCrawl();
    const queue = [...seedUrls];
    const visited = new Set();
    const findings = [];

    while (this.isRunning && queue.length > 0) {
      if (this.throttler.needsCooldown()) {
        this.onStatusUpdate?.(`😴 Cooldown: ${Math.ceil(this.throttler.getCooldownRemaining() / 60000)} minutes remaining`);
        await new Promise(resolve => setTimeout(resolve, 5000));
        continue;
      }

      const url = queue.shift();
      if (visited.has(url)) continue;
      visited.add(url);

      this.onStatusUpdate?.(`🕷️ Crawling: ${url} (Depth: ${visited.size})`);
      
      try {
        const response = await this.intelligentCrawl(url, visited.size);
        if (response) {
          const extracted = this.extractFindings(response, url);
          findings.push(...extracted);
          this.onFinding?.(extracted);
          
          const newUrls = this.extractUrls(response.content);
          newUrls.forEach(u => { if (!visited.has(u) && queue.length < 500) queue.push(u); });
        }
      } catch (error) {
        this.onStatusUpdate?.(`⚠️ Failed: ${url} - ${error.message}`);
        if (error.statusCode === 429) await new Promise(resolve => setTimeout(resolve, 30000));
      }
    }
    
    return findings;
  }

  extractFindings(response, sourceUrl) {
    try {
      const data = JSON.parse(response.content);
      return data.iocs.map(ioc => ({
        id: `${Date.now()}-${Math.random()}`,
        ...ioc,
        source: sourceUrl,
        timestamp: new Date().toISOString(),
        confidence: Math.random() * 100,
        verified: false
      }));
    } catch {
      return [];
    }
  }

  extractUrls(content) {
    const urls = [];
    const urlRegex = /https?:\/\/[^\s<>"{}|\\^`[\]]+/g;
    const matches = content.match(urlRegex);
    if (matches) urls.push(...matches);
    for (let i = 0; i < Math.min(3, Math.floor(Math.random() * 5)); i++) {
      urls.push(`https://related-${Math.random().toString(36).substring(7)}.com/page`);
    }
    return [...new Set(urls)];
  }

  stop() {
    this.isRunning = false;
  }

  getStatus() {
    return {
      ml: this.mlModel.getStatus(),
      throttle: this.throttler.getStatus(),
      running: this.isRunning,
      requestsMade: this.requestCount,
      userAgent: this.currentUserAgent.substring(0, 50) + '...'
    };
  }
}

