                  type="text"
                  value={newUrl}
                  onChange={(e) => setNewUrl(e.target.value)}
                  placeholder="Enter URL to crawl..."
                  className="flex-1 bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-blue-500"
                  onKeyPress={(e) => e.key === 'Enter' && addSeedUrl()}
                />
                <button onClick={addSeedUrl} className="bg-blue-600 hover:bg-blue-700 px-4 rounded-lg transition">Add</button>
              </div>
            </div>

            {/* Status Dashboard */}
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
              <div className="bg-gradient-to-br from-slate-800 to-slate-800/50 p-4 rounded-xl border border-slate-700 backdrop-blur-sm">
                <div className="flex items-center justify-between mb-2">
                  <span className="text-slate-400">ML Behavior</span>
                  <Brain size={20} className="text-purple-400" />
                </div>
                <p className="text-2xl font-bold text-white capitalize">{crawlState.crawlerStatus?.ml?.behavior || 'Idle'}</p>
                <p className="text-xs text-slate-400 mt-1">Delay: {crawlState.crawlerStatus?.ml?.delay || 0}ms</p>
              </div>
              
              <div className="bg-gradient-to-br from-slate-800 to-slate-800/50 p-4 rounded-xl border border-slate-700">
                <div className="flex items-center justify-between mb-2">
                  <span className="text-slate-400">Request Rate</span>
                  <Activity size={20} className="text-blue-400" />
                </div>
                <p className="text-2xl font-bold text-white">{crawlState.crawlerStatus?.throttle?.requestRate || 0}/min</p>
                <p className="text-xs text-slate-400 mt-1">Total: {crawlState.crawlerStatus?.requestsMade || 0}</p>
              </div>
              
              <div className="bg-gradient-to-br from-slate-800 to-slate-800/50 p-4 rounded-xl border border-slate-700">
                <div className="flex items-center justify-between mb-2">
                  <span className="text-slate-400">Cooldown</span>
                  {crawlState.cooldownRemaining > 0 ? <Coffee size={20} className="text-orange-400 animate-pulse" /> : <Battery size={20} className="text-green-400" />}
                </div>
                <p className="text-2xl font-bold text-white">
                  {crawlState.cooldownRemaining > 0 ? `${Math.ceil(crawlState.cooldownRemaining / 60000)}m` : 'Ready'}
                </p>
                <p className="text-xs text-slate-400 mt-1">{crawlState.cooldownRemaining > 0 ? 'Rest mode' : 'Active'}</p>
              </div>
              
              <div className="bg-gradient-to-br from-slate-800 to-slate-800/50 p-4 rounded-xl border border-slate-700">
                <div className="flex items-center justify-between mb-2">
                  <span className="text-slate-400">Findings</span>
                  <AlertTriangle size={20} className="text-yellow-400" />
                </div>
                <p className="text-2xl font-bold text-white">{crawlState.findings.length}</p>
                <p className="text-xs text-slate-400 mt-1">Pages: {crawlState.pagesCrawled}</p>
              </div>
            </div>

            {/* Current Status Bar */}
            {(crawlState.isRunning || crawlState.cooldownRemaining > 0) && (
              <div className="bg-gradient-to-r from-slate-800 to-slate-800/50 p-4 rounded-xl border border-slate-700">
                <div className="flex items-center justify-between mb-2">
                  <div className="flex items-center gap-2">
                    {crawlState.cooldownRemaining > 0 ? (
                      <><Coffee size={18} className="text-orange-400" /><span className="text-orange-400 font-semibold">Cooldown Active</span></>
                    ) : (
                      <><Zap size={18} className="text-yellow-400" /><span className="text-yellow-400 font-semibold">Actively Crawling</span></>
                    )}
                  </div>
                  <div className="text-xs text-slate-400 font-mono">{crawlState.currentStatus}</div>
                </div>
                
                {crawlState.cooldownRemaining > 0 && (
                  <div className="mt-2">
                    <div className="bg-slate-700 rounded-full h-2 overflow-hidden">
                      <div className="bg-gradient-to-r from-orange-500 to-red-500 h-2 transition-all duration-1000" style={{ width: `${(1 - crawlState.cooldownRemaining / EVASION_CONFIG.COOLDOWN.DURATION) * 100}%` }} />
                    </div>
                    <p className="text-xs text-slate-400 mt-1">Next crawl in {Math.floor(crawlState.cooldownRemaining / 60000)}m {Math.floor((crawlState.cooldownRemaining % 60000) / 1000)}s</p>
                  </div>
                )}
              </div>
            )}

            {/* Real-time Findings Feed */}
            <div className="bg-slate-800/50 backdrop-blur-sm rounded-xl border border-slate-700">
              <div className="p-4 border-b border-slate-700">
                <h3 className="font-semibold text-white flex items-center gap-2">
                  <Radio size={18} className="text-green-400 animate-pulse" />
                  Real-time Intelligence Feed
                </h3>
              </div>
              <div className="p-4 max-h-96 overflow-y-auto space-y-2">
                {crawlState.findings.slice(0, 50).map((finding, idx) => (
                  <div key={finding.id || idx} className="bg-slate-900 p-3 rounded-lg hover:bg-slate-900/80 transition">
                    <div className="flex justify-between items-start">
                      <div className="flex items-center gap-2">
                        {finding.type === 'ip_address' && <Network size={14} className="text-blue-400" />}
                        {finding.type === 'domain' && <Globe size={14} className="text-green-400" />}
                        {finding.type === 'hash' && <Hash size={14} className="text-purple-400" />}
                        {finding.type === 'cve' && <Bug size={14} className="text-red-400" />}
                        <code className="text-sm text-blue-400">{finding.value}</code>
                      </div>
                      <span className="text-xs text-slate-500">{new Date(finding.timestamp).toLocaleTimeString()}</span>
                    </div>
                    <p className="text-xs text-slate-400 mt-1">Source: {finding.source}</p>
                    <div className="flex gap-2 mt-2">
                      <span className="text-xs bg-blue-500/20 text-blue-300 px-2 py-0.5 rounded">Confidence: {Math.round(finding.confidence)}%</span>
                      {finding.verified && <span className="text-xs bg-green-500/20 text-green-300 px-2 py-0.5 rounded">Verified</span>}
                    </div>
                  </div>
                ))}
                {crawlState.findings.length === 0 && (
                  <div className="text-center text-slate-500 py-8">
                    <EyeOff size={32} className="mx-auto mb-2 opacity-50" />
                    <p>No findings yet. Start a crawl to gather intelligence.</p>
                  </div>
                )}
              </div>
            </div>

            {/* ML Insights & Evasion Stats */}
            <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
              <div className="bg-gradient-to-br from-purple-900/20 to-slate-800/50 rounded-xl border border-purple-800 p-4">
                <h3 className="font-semibold text-white mb-3 flex items-center gap-2">
                  <Brain size={18} className="text-purple-400" />
                  ML Behavioral Insights
                </h3>
                <div className="space-y-2 text-sm">
                  <div className="flex justify-between">
                    <span className="text-slate-400">Learned Patterns</span>
                    <span className="text-white">{crawlState.crawlerStatus?.ml?.learnedPatterns || 0}</span>
                  </div>
                  <div className="flex justify-between">
                    <span className="text-slate-400">Blocks Avoided</span>
                    <span className="text-white">{crawlState.crawlerStatus?.ml?.blocksAvoided || 0}</span>
                  </div>
                  <div className="flex justify-between">
                    <span className="text-slate-400">Current User-Agent</span>
                    <span className="text-white text-xs">{crawlState.crawlerStatus?.userAgent || 'Rotating'}</span>
                  </div>
                </div>
              </div>
              
              <div className="bg-gradient-to-br from-green-900/20 to-slate-800/50 rounded-xl border border-green-800 p-4">
                <h3 className="font-semibold text-white mb-3 flex items-center gap-2">
                  <ShieldCheck size={18} className="text-green-400" />
                  Evasion Techniques Active
                </h3>
                <div className="flex flex-wrap gap-2">
                  <span className="text-xs bg-green-500/20 text-green-300 px-2 py-1 rounded">UA Rotation</span>
                  <span className="text-xs bg-green-500/20 text-green-300 px-2 py-1 rounded">Fake Referrers</span>
                  <span className="text-xs bg-green-500/20 text-green-300 px-2 py-1 rounded">Human Timing</span>
                  <span className="text-xs bg-green-500/20 text-green-300 px-2 py-1 rounded">Session Persistence</span>
                  <span className="text-xs bg-green-500/20 text-green-300 px-2 py-1 rounded">Rate Limit Bypass</span>
                  <span className="text-xs bg-green-500/20 text-green-300 px-2 py-1 rounded">AJAX Mimicry</span>
                  <span className="text-xs bg-orange-500/20 text-orange-300 px-2 py-1 rounded">30min Cooldown/6hr</span>
                </div>
                <p className="text-xs text-slate-400 mt-3">Cooldown every 6 hours for 30 minutes ensures undetectable crawling patterns</p>
              </div>
            </div>
          </div>
        )}

        {/* Investigations View */}
        {currentView === 'investigations' && (
          <div className="space-y-6">
            <div className="flex justify-between items-center">
              <div>
                <h2 className="text-3xl font-bold text-white">360° Investigations</h2>
                <p className="text-slate-400 mt-1">Victim assistance & attack analysis</p>
              </div>
              <button onClick={createInvestigation} className="bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 px-4 py-2 rounded-lg flex items-center gap-2 transition-all">
                <Plus size={18} /> New Investigation
              </button>
            </div>

            <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
              {/* Investigations List */}
              <div className="lg:col-span-1 space-y-3">
                {investigations.map(inv => (
                  <div key={inv.id} onClick={() => setActiveInvestigation(inv)} className={`bg-slate-800/50 backdrop-blur-sm p-4 rounded-xl border cursor-pointer transition-all hover:scale-105 ${activeInvestigation?.id === inv.id ? 'border-blue-500 shadow-lg shadow-blue-500/20' : 'border-slate-700'}`}>
                    <div className="flex justify-between items-start mb-2">
                      <p className="font-mono text-sm text-blue-400">{inv.caseId}</p>
                      <span className={`text-xs px-2 py-1 rounded ${inv.severity === 'critical' ? 'bg-red-500/20 text-red-400' : 'bg-yellow-500/20 text-yellow-400'}`}>
                        {inv.severity?.toUpperCase() || 'ACTIVE'}
                      </span>
                    </div>
                    <p className="text-white font-semibold">{inv.victim?.name || 'Unknown Victim'}</p>
                    <p className="text-xs text-slate-400 mt-1">Started: {new Date(inv.startDate).toLocaleDateString()}</p>
                    <div className="flex gap-2 mt-3">
                      <span className="text-xs bg-slate-700 px-2 py-0.5 rounded">{inv.findings?.length || 0} findings</span>
                      <span className="text-xs bg-slate-700 px-2 py-0.5 rounded capitalize">{inv.status}</span>
                    </div>
                  </div>
                ))}
                {investigations.length === 0 && (
                  <div className="bg-slate-800/50 rounded-xl p-8 text-center border border-slate-700">
                    <Target size={32} className="mx-auto mb-2 text-slate-500" />
                    <p className="text-slate-400">No investigations yet</p>
                    <button onClick={createInvestigation} className="mt-3 text-blue-400 hover:text-blue-300">Create your first investigation →</button>
                  </div>
                )}
              </div>

              {/* Investigation Details */}
              <div className="lg:col-span-2">
                {activeInvestigation ? (
                  <div className="bg-gradient-to-br from-slate-800/80 to-slate-800/50 rounded-xl border border-slate-700 p-6 backdrop-blur-sm">
                    <div className="flex justify-between items-start mb-6">
                      <div>
                        <h3 className="text-2xl font-bold text-white">{activeInvestigation.caseId}</h3>
                        <p className="text-slate-400">Victim: {activeInvestigation.victim?.name}</p>
                      </div>
                      <div className="flex gap-2">
                        <button className="bg-blue-600/50 hover:bg-blue-600 px-3 py-1 rounded text-sm transition">Export Report</button>
                        <button className="bg-green-600/50 hover:bg-green-600 px-3 py-1 rounded text-sm transition">Share IOCs</button>
                      </div>
                    </div>

                    {/* Stats Overview */}
                    <div className="grid grid-cols-3 gap-4 mb-6">
                      <div className="bg-slate-900/50 p-3 rounded-lg text-center">
                        <p className="text-2xl font-bold text-white">{activeInvestigation.findings?.length || 0}</p>
                        <p className="text-xs text-slate-400">Total Findings</p>
                      </div>
                      <div className="bg-slate-900/50 p-3 rounded-lg text-center">
                        <p className="text-2xl font-bold text-white">{activeInvestigation.findings?.filter(f => f.type === 'ip_address').length || 0}</p>
                        <p className="text-xs text-slate-400">IP Addresses</p>
                      </div>
                      <div className="bg-slate-900/50 p-3 rounded-lg text-center">
                        <p className="text-2xl font-bold text-white">{activeInvestigation.findings?.filter(f => f.type === 'domain').length || 0}</p>
                        <p className="text-xs text-slate-400">Domains</p>
                      </div>
                    </div>

                    {/* IOC List */}
                    <div className="mb-6">
                      <h4 className="text-white font-semibold mb-3 flex items-center gap-2">
                        <FileSearch size={16} className="text-blue-400" />
                        Extracted IOCs
                      </h4>
                      <div className="space-y-2 max-h-96 overflow-y-auto">
                        {activeInvestigation.findings?.slice(0, 20).map((finding, idx) => (
                          <div key={idx} className="bg-slate-900/50 p-2 rounded-lg">
                            <div className="flex justify-between items-center">
                              <code className="text-sm text-blue-400">{finding.value}</code>
                              <span className="text-xs text-slate-500">{finding.type}</span>
                            </div>
                            <p className="text-xs text-slate-400 mt-1">Source: {finding.source}</p>
                          </div>
                        ))}
                      </div>
                    </div>

                    {/* MITRE ATT&CK Mapping */}
                    <div className="bg-purple-900/20 border border-purple-800 rounded-lg p-4">
                      <h4 className="text-white font-semibold mb-2 flex items-center gap-2">
                        <Target size={16} className="text-purple-400" />
                        MITRE ATT&CK Mapping
                      </h4>
                      <div className="flex flex-wrap gap-2">
                        <span className="text-xs bg-purple-500/20 text-purple-300 px-2 py-1 rounded">T1071 - C2</span>
                        <span className="text-xs bg-purple-500/20 text-purple-300 px-2 py-1 rounded">T1568 - Dynamic Resolution</span>
                        <span className="text-xs bg-purple-500/20 text-purple-300 px-2 py-1 rounded">T1583 - Infrastructure</span>
                      </div>
                    </div>
                  </div>
                ) : (
                  <div className="bg-slate-800/50 rounded-xl border border-slate-700 p-12 text-center">
                    <Target size={48} className="text-slate-600 mx-auto mb-4" />
                    <p className="text-slate-400">Select an investigation or create a new one</p>
                  </div>
                )}
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

// Simple Plus icon component
const Plus = ({ size, className }) => (
  <svg className={className} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
    <path d="M12 5v14M5 12h14" />
  </svg>
);
